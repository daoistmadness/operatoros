{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "OperatorOS Desktop Shell Capabilities",
  "windows": ["main", "startup"],
  "permissions": [
    "core:default",
    {
      "identifier": "core:default",
      "allow": [
        { "cmd": "get_lifecycle_state" },
        { "cmd": "retry_startup" },
        { "cmd": "exit_application" },
        { "cmd": "launch_main_window" }
      ]
    }
  ]
}
