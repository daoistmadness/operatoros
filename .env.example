# Backend
DATABASE_URL=sqlite:///./attendance.db
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
HOST=0.0.0.0
PORT=8000
ENABLE_DESTRUCTIVE_OPERATIONS=false

# Preferred local launcher mode
DEV_USE_PORTLESS=true
PORTLESS_FRONTEND_NAME=school-attendance
PORTLESS_BACKEND_NAME=api.school-attendance
DEV_VERIFY_BROWSER=false
DEV_BROWSER_ARTIFACT_DIR=.artifacts/browser

# Frontend build-time API base URL for direct local development
REACT_APP_API_URL=http://localhost:8000
# Portless and Docker use /api; the Portless launcher sets this automatically when needed.
DEV_API_PROXY_TARGET=http://localhost:8000

# WSL2 dev script overrides for the non-Portless fallback
DEV_BACKEND_HOST=0.0.0.0
DEV_BACKEND_PORT=8000
DEV_FRONTEND_PORT=3000

# Docker Compose database settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=absensi
POSTGRES_HOST=db
POSTGRES_PORT=5432
