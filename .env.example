# Backend
DATABASE_URL=sqlite:///./attendance.db
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
HOST=127.0.0.1
PORT=8000
ENABLE_DESTRUCTIVE_OPERATIONS=false

# Persistent HMAC secret for opaque server-side sessions. Minimum 32 characters.
# Generate once with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Copy .env.example to .env and store the generated value there. Never commit or print it.
AUTH_COOKIE_SECRET=
# Optional for direct loopback development; required by Docker/server setup.
# Generate once with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Remove it from deployed secrets after the first administrator is provisioned.
ASTRYX_SETUP_TOKEN=
# false for localhost HTTP; true only when the browser uses HTTPS.
COOKIE_SECURE=false
# Sliding idle lifetime and hard absolute lifetime for database sessions.
SESSION_IDLE_TIMEOUT_HOURS=6
SESSION_ABSOLUTE_TIMEOUT_HOURS=24
# Temporary lockout policy for consecutive failed logins.
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30
# Must match the actual Uvicorn worker count. Restore fails closed above one.
BACKEND_WORKERS=1
# Keep true until an approved cross-process restore lock exists.
RESTORE_SINGLE_WORKER_REQUIRED=true

# Frontend API base URL
# Leave empty to use the Vite development proxy (recommended for local development).
# The Vite proxy forwards /api/* from http://localhost:5173 to http://127.0.0.1:8000.
VITE_API_BASE_URL=

# Set this for standalone deployments where the frontend is served separately from the backend.
# Example: VITE_API_BASE_URL=http://127.0.0.1:8000

# Desktop (Tauri) runtime injection — set by the desktop launcher at runtime, not here.
# window.__APP_CONFIG__ = { apiBaseUrl: "http://127.0.0.1:<dynamic-port>" }

# Development server address overrides
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173

# Docker Compose database settings
POSTGRES_USER=postgres
# Required by Compose. Set a non-example value in the gitignored .env file.
POSTGRES_PASSWORD=
POSTGRES_DB=absensi
POSTGRES_HOST=db
POSTGRES_PORT=5432
